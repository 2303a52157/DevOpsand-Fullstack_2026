<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="page-header">
        <a href="/clubs" class="topbar-btn btn-ghost">← Clubs</a>
        <div style="display:flex;gap:10px;">
          <% if (isMember && !isCreator) { %>
            <form method="POST" action="/clubs/<%= club._id %>/leave">
              <button type="submit" class="topbar-btn btn-ghost">Leave Club</button>
            </form>
          <% } %>
          <% if (!isMember) { %>
            <form method="POST" action="/clubs/<%= club._id %>/join">
              <button type="submit" class="topbar-btn btn-primary">Join Club</button>
            </form>
          <% } %>
          <% if (isCreator || isAdmin) { %>
            <form id="deleteClubForm" method="POST" action="/clubs/<%= club._id %>?_method=DELETE">
              <button type="button" class="topbar-btn btn-danger" onclick="openDeleteModal('deleteClubForm')">Delete Club</button>
            </form>
          <% } %>
        </div>
      </div>

      <!-- Club Header -->
      <div class="card mb-24">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
              <h1 style="font-size:2rem;"><%= club.name %></h1>
              <% if (club.isPrivate) { %><span class="badge badge-dropped">🔒 Private</span><% } else { %><span class="badge badge-want">🌐 Public</span><% } %>
            </div>
            <p style="color:var(--text-muted);"><%= club.description || 'No description provided.' %></p>
            <div style="margin-top:10px;display:flex;gap:16px;font-size:0.88rem;color:var(--text-muted);">
              <span>🏷️ Genre: <strong style="color:var(--text-secondary);"><%= club.genre %></strong></span>
              <span>📅 Created: <strong style="color:var(--text-secondary);"><%= new Date(club.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></strong></span>
              <span>👤 By: <strong style="color:var(--text-secondary);"><%= club.createdBy ? club.createdBy.name : 'Unknown' %></strong></span>
            </div>
          </div>
          <% if (club.currentBook) { %>
          <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;min-width:200px;">
            <div class="mono" style="font-size:0.65rem;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.1em;">Currently Reading</div>
            <div style="color:var(--text-primary);font-weight:500;"><%= club.currentBook.title %></div>
            <div style="color:var(--text-muted);font-style:italic;font-size:0.88rem;"><%= club.currentBook.author %></div>
          </div>
          <% } %>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 280px;gap:24px;">

        <!-- Books in Club -->
        <div>
          <div class="section-title">Club Reading List (<%= books.length %>)</div>
          <% if (books.length > 0) { %>
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Title</th><th>Author</th><th>Genre</th><th>Status</th></tr></thead>
              <tbody>
                <% books.forEach(b => { %>
                <tr>
                  <td class="strong"><a href="/books/<%= b._id %>" style="color:var(--text-primary);"><%= b.title %></a></td>
                  <td class="italic"><%= b.author %></td>
                  <td><span class="tag"><%= b.genre %></span></td>
                  <td>
                    <% const sc = {completed:'badge-completed','currently-reading':'badge-reading','want-to-read':'badge-want',dropped:'badge-dropped'}; %>
                    <span class="badge <%= sc[b.status] || 'badge-want' %>"><%= b.status %></span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
          <div class="empty-state" style="padding:32px 0;">
            <div class="empty-icon">📚</div>
            <h3>No books yet</h3>
            <p>Members can add books to this club from their library.</p>
          </div>
          <% } %>
        </div>

        <!-- Members -->
        <div>
          <div class="section-title">Members (<%= club.members.length %>)</div>
          <div class="card">
            <div class="member-chips" style="flex-direction:column;gap:10px;">
              <% club.members.forEach(member => { %>
              <div class="member-chip" style="border-radius:var(--radius);padding:8px 12px;">
                <div class="member-chip-avatar" style="width:32px;height:32px;font-size:0.9rem;">
                  <% if (member.avatar) { %>
                    <img src="<%= member.avatar %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />
                  <% } else { %>
                    👤
                  <% } %>
                </div>
                <div>
                  <div style="color:var(--text-primary);font-size:0.9rem;"><%= member.name %></div>
                  <% if (club.createdBy && member._id.toString() === club.createdBy._id.toString()) { %>
                    <div class="mono" style="font-size:0.62rem;color:var(--accent);">CREATOR</div>
                  <% } %>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>
<%- include('../partials/delete-modal') %>
<%- include('../partials/scripts') %>
