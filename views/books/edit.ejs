<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="page-header">
        <div>
          <h1>Edit Book</h1>
          <p>Update details for "<%= book.title %>"</p>
        </div>
        <a href="/books/<%= book._id %>" class="topbar-btn btn-ghost">← Back</a>
      </div>

      <form method="POST" action="/books/<%= book._id %>?_method=PUT" enctype="multipart/form-data">
        <div style="display:grid;grid-template-columns:220px 1fr;gap:28px;align-items:start;">

          <div>
            <div class="card" style="text-align:center;">
              <label style="text-transform:none;font-family:'Crimson Pro',serif;font-size:0.95rem;cursor:pointer;display:block;" for="coverImageInput">
                <% if (book.coverImage) { %>
                  <img id="coverPreview" src="<%= book.coverImage %>" style="width:100%;aspect-ratio:2/3;object-fit:cover;border-radius:4px;margin-bottom:12px;" />
                  <div id="coverPlaceholder" style="display:none;width:100%;aspect-ratio:2/3;background:var(--bg-hover);border-radius:4px;align-items:center;justify-content:center;font-size:4rem;color:var(--border-light);margin-bottom:12px;">📖</div>
                <% } else { %>
                  <div id="coverPlaceholder" style="width:100%;aspect-ratio:2/3;background:var(--bg-hover);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:4rem;color:var(--border-light);margin-bottom:12px;">📖</div>
                  <img id="coverPreview" style="display:none;width:100%;aspect-ratio:2/3;object-fit:cover;border-radius:4px;margin-bottom:12px;" />
                <% } %>
                <span style="color:var(--accent);font-size:0.88rem;">Click to change cover</span>
              </label>
              <input type="file" id="coverImageInput" name="coverImage" accept="image/*" style="display:none;" onchange="previewCover(this)" />
            </div>
          </div>

          <div>
            <div class="card">
              <div class="form-row">
                <div class="form-group">
                  <label>Title *</label>
                  <input type="text" name="title" value="<%= book.title %>" required />
                </div>
                <div class="form-group">
                  <label>Author *</label>
                  <input type="text" name="author" value="<%= book.author %>" required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Genre *</label>
                  <select name="genre" required>
                    <% genres.forEach(g => { %><option value="<%= g %>" <%= book.genre === g ? 'selected' : '' %>><%= g %></option><% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label>Status</label>
                  <select name="status">
                    <% statuses.forEach(s => { %><option value="<%= s %>" <%= book.status === s ? 'selected' : '' %>><%= s %></option><% }) %>
                  </select>
                </div>
              </div>
              <div class="form-row-3">
                <div class="form-group">
                  <label>ISBN</label>
                  <input type="text" name="isbn" value="<%= book.isbn || '' %>" />
                </div>
                <div class="form-group">
                  <label>Published Year</label>
                  <input type="number" name="publishedYear" value="<%= book.publishedYear || '' %>" />
                </div>
                <div class="form-group">
                  <label>Pages</label>
                  <input type="number" name="pages" value="<%= book.pages || '' %>" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Start Date</label>
                  <input type="date" name="startDate" value="<%= book.startDate ? new Date(book.startDate).toISOString().split('T')[0] : '' %>" />
                </div>
                <div class="form-group">
                  <label>Finish Date</label>
                  <input type="date" name="finishDate" value="<%= book.finishDate ? new Date(book.finishDate).toISOString().split('T')[0] : '' %>" />
                </div>
              </div>
              <div class="form-group">
                <label>Description / Notes</label>
                <textarea name="description" rows="4"><%= book.description || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Tags</label>
                <input type="text" name="tags" value="<%= (book.tags || []).join(', ') %>" placeholder="classic, favourite (comma separated)" />
              </div>
              <div style="display:flex;gap:12px;margin-top:8px;">
                <button type="submit" class="topbar-btn btn-primary" style="padding:11px 28px;">Update Book</button>
                <a href="/books/<%= book._id %>" class="topbar-btn btn-ghost" style="padding:11px 20px;">Cancel</a>
              </div>
            </div>
          </div>

        </div>
      </form>
    </div>
  </div>
</div>
<script>
function previewCover(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('coverPreview').src = e.target.result;
    document.getElementById('coverPreview').style.display = 'block';
    const ph = document.getElementById('coverPlaceholder');
    if(ph) ph.style.display = 'none';
  };
  reader.readAsDataURL(file);
}
</script>
<%- include('../partials/scripts') %>
