<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <div class="page-header">
        <div>
          <h1>My Library</h1>
          <p><%= books.length %> book<%= books.length !== 1 ? 's' : '' %> in your collection</p>
        </div>
        <a href="/books/create" class="topbar-btn btn-primary">+ Add Book</a>
      </div>

      <!-- Filters -->
      <form method="GET" action="/books">
        <div class="filter-bar">
          <div class="filter-group">
            <label>Search</label>
            <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search by title…" style="min-width:220px;" />
          </div>
          <div class="filter-group">
            <label>Genre</label>
            <select name="genre">
              <option value="">All Genres</option>
              <% genres.forEach(g => { %><option value="<%= g %>" <%= filters.genre === g ? 'selected' : '' %>><%= g %></option><% }) %>
            </select>
          </div>
          <div class="filter-group">
            <label>Status</label>
            <select name="status">
              <option value="">All Statuses</option>
              <% statuses.forEach(s => { %><option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option><% }) %>
            </select>
          </div>
          <div class="filter-group">
            <label>Sort By</label>
            <select name="sort">
              <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
              <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
              <option value="title"  <%= filters.sort === 'title'  ? 'selected' : '' %>>Title A–Z</option>
              <option value="author" <%= filters.sort === 'author' ? 'selected' : '' %>>Author A–Z</option>
            </select>
          </div>
          <div class="filter-group" style="justify-content:flex-end;">
            <label>&nbsp;</label>
            <button type="submit" class="topbar-btn btn-primary">Filter</button>
          </div>
          <% if (filters.search || filters.genre || filters.status) { %>
          <div class="filter-group" style="justify-content:flex-end;">
            <label>&nbsp;</label>
            <a href="/books" class="topbar-btn btn-ghost">Clear</a>
          </div>
          <% } %>
        </div>
      </form>

      <% if (books.length > 0) { %>
      <div class="books-grid">
        <% books.forEach(book => { %>
        <a href="/books/<%= book._id %>" class="book-card" style="text-decoration:none;">
          <% if (book.coverImage) { %>
            <img src="<%= book.coverImage %>" alt="<%= book.title %>" class="book-cover" loading="lazy" />
          <% } else { %>
            <div class="book-cover-placeholder">📖</div>
          <% } %>
          <div class="book-info">
            <div class="book-title"><%= book.title %></div>
            <div class="book-author"><%= book.author %></div>
            <% const sc = {completed:'badge-completed','currently-reading':'badge-reading','want-to-read':'badge-want',dropped:'badge-dropped'}; %>
            <span class="badge <%= sc[book.status] || 'badge-want' %>" style="font-size:0.65rem;"><%= book.status %></span>
          </div>
        </a>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📚</div>
        <h3>No books found</h3>
        <p>Try adjusting your filters or <a href="/books/create">add a new book</a>.</p>
      </div>
      <% } %>

    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
